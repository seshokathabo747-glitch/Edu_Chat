*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, Helvetica, sans-serif;
}

body{
    background:#ece5dd;
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
}

.container{
    width:100%;
    max-width:500px;
    height:100vh;
    background:#fff;
    display:flex;
    flex-direction:column;
    box-shadow:0 0 10px rgba(0,0,0,.2);
}

.header{
    background:#075E54;
    color:#fff;
    padding:15px;
    display:flex;
    justify-content:space-between;
    align-items:center;
}

.header h2{
    font-size:24px;
}

#myName{
    font-size:14px;
    font-weight:bold;
}

.messages{
    flex:1;
    overflow-y:auto;
    padding:15px;
    background:#e5ddd5;
    display:flex;
    flex-direction:column;
}

.message{
    max-width:80%;
    margin-bottom:12px;
    padding:10px 14px;
    border-radius:15px;
    background:#fff;
    box-shadow:0 1px 3px rgba(0,0,0,.15);
    word-wrap:break-word;
}

.message .name{
    font-weight:bold;
    color:#075E54;
    margin-bottom:5px;
}

.message .text{
    color:#222;
    font-size:15px;
}

.message .time{
    text-align:right;
    color:#777;
    font-size:11px;
    margin-top:6px;
}

.verified{
    color:#1DA1F2;
    font-size:14px;
    margin-left:5px;
}

.bottom{
    display:flex;
    gap:10px;
    padding:10px;
    background:#fff;
    border-top:1px solid #ddd;
}

.bottom input{
    flex:1;
    padding:12px;
    border:1px solid #ccc;
    border-radius:25px;
    outline:none;
    font-size:16px;
}

.bottom button{
    padding:12px 20px;
    background:#128C7E;
    color:#fff;
    border:none;
    border-radius:25px;
    cursor:pointer;
    font-size:16px;
}

.bottom button:hover{
    background:#0b6d61;
}

.messages::-webkit-scrollbar{
    width:6px;
}

.messages::-webkit-scrollbar-thumb{
    background:#999;
    border-radius:10px;
}

@media(max-width:600px){

.container{
    max-width:100%;
}

.header h2{
    font-size:20px;
}

.bottom input{
    font-size:15px;
}

.bottom button{
    font-size:15px;
    padding:12px 16px;
}

}